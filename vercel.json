{
  "framework": "nextjs",
  "regions": ["fra1"],
  "functions": {
    "app/api/narrate/route.ts": { "runtime": "edge", "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=30"
        }
      ]
    }
  ]
}
